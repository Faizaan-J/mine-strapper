{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Minestrapper Configuration",
  "type": "object",
  "required": [
    "server",
    "features"
  ],
  "properties": {
    "server": {
      "type": "object",
      "description": "Minecraft Server launch settings.",
      "required": [
        "min_ram",
        "max_ram",
        "jar_name"
      ],
      "properties": {
        "min_ram": {
          "type": "string",
          "description": "Minimum JVM memory allocation.",
          "default": "1G",
          "x-placeholder": "e.g. 512M, 1G, 2G"
        },
        "max_ram": {
          "type": "string",
          "description": "Maximum JVM memory allocation.",
          "default": "2G",
          "x-placeholder": "e.g. 512M, 1G, 2G"
        },
        "jar_name": {
          "type": "string",
          "description": "Server .jar file name without extension.",
          "x-placeholder": "Server Name Here.jar"
        },
        "other_args": {
          "type": "array",
          "description": "Additional JVM arguments.",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "features": {
      "type": "object",
      "required": [
        "state_styles",
        "server_resource_pack"
      ],
      "properties": {
        "state_styles": {
          "$ref": "#/$defs/stateStylesFeature"
        },
        "server_resource_pack": {
          "$ref": "#/$defs/serverResourcePackFeature"
        }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "style": {
      "type": "object",
      "required": [
        "title",
        "color"
      ],
      "properties": {
        "title": {
          "type": "string",
          "description": "Display title for this state.",
          "x-placeholder": "e.g. Starting, Running, Stopping"
        },
        "color": {
          "type": "string",
          "description": "Display color for this state.",
          "enum": [
            "red",
            "bright_red",
            "green",
            "bright_green",
            "yellow",
            "bright_yellow",
            "blue",
            "bright_blue",
            "magenta",
            "bright_magenta",
            "cyan",
            "bright_cyan",
            "white",
            "bright_white",
            "black",
            "bright_black"
          ]
        }
      },
      "additionalProperties": false
    },
    "stateStylesFeature": {
      "type": "object",
      "required": [
        "feature_enabled"
      ],
      "properties": {
        "feature_enabled": {
          "type": "boolean",
          "description": "Enable or disable this feature."
        },
        "title_enabled": {
          "type": "boolean",
          "description": "Show state titles."
        },
        "color_enabled": {
          "type": "boolean",
          "description": "Enable colored state output."
        },
        "styles": {
          "type": "object",
          "description": "Style definitions for server states.",
          "properties": {
            "starting": {
              "$ref": "#/$defs/style"
            },
            "running": {
              "$ref": "#/$defs/style"
            },
            "stopping": {
              "$ref": "#/$defs/style"
            },
            "stopped": {
              "$ref": "#/$defs/style"
            },
            "paused": {
              "$ref": "#/$defs/style"
            }
          },
          "additionalProperties": {
            "$ref": "#/$defs/style"
          }
        }
      },
      "if": {
        "properties": {
          "feature_enabled": {
            "const": true
          }
        }
      },
      "then": {
        "required": [
          "title_enabled",
          "color_enabled",
          "styles"
        ]
      },
      "additionalProperties": false
    },
    "serverResourcePackFeature": {
      "type": "object",
      "required": [
        "feature_enabled"
      ],
      "properties": {
        "feature_enabled": {
          "type": "boolean",
          "description": "Enable or disable this feature."
        },
        "path": {
          "type": "string",
          "description": "Path to the resource pack ZIP file relative to the server directory.",
          "x-placeholder": "e.g. resourcepacks/my_pack.zip"
        },
        "ip": {
          "type": "string",
          "description": "IP address used to host the resource pack. If empty, it defaults to 0.0.0.0.",
          "default": "0.0.0.0"
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535,
          "description": "Port used to host the resource pack.",
          "default": 6940,
          "x-placeholder": "e.g. 2601"
        }
      },
      "if": {
        "properties": {
          "feature_enabled": {
            "const": true
          }
        }
      },
      "then": {
        "required": [
          "path",
          "port"
        ]
      },
      "additionalProperties": false
    }
  }
}
